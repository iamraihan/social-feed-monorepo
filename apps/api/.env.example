# ---- App ----
NODE_ENV=development
PORT=8000

# ---- Postgres ----
POSTGRES_USER=social_feed
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_DB=social_feed
POSTGRES_HOST=localhost
# Non-standard host port to avoid colliding with a local Postgres install on 5432.
POSTGRES_PORT=5434

# Prisma — read by prisma CLI and PrismaPg adapter at runtime
DATABASE_URL="postgresql://social_feed:change_me_in_local_env@localhost:5434/social_feed?schema=public"

# ---- Redis (access-token revocation blocklist; refresh tokens live in Postgres) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_local_env

# ---- JWT / Auth ----
# Generate the secret with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_to_a_64_char_random_string
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ---- CORS ----
# Comma-separated list of allowed origins for the SPA (required in production).
# Example: CORS_ORIGIN=https://app.example.com,https://admin.example.com
# Leave empty in dev — the app falls back to reflecting the request origin.
CORS_ORIGIN=

# ---- Reverse proxy ----
# Number of trusted proxy hops in front of the API (k8s ingress = 1,
# ingress + service mesh = 2, etc.). Affects req.ip used by the rate limiter.
TRUSTED_PROXY_HOPS=1

# ---- Storage ----
# Local disk in this build. Swap StorageService impl for S3 / MinIO in prod.
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8000
MAX_IMAGE_SIZE_MB=5

# ---- pgAdmin (development only — remove for production delivery) ----
PGADMIN_DEFAULT_EMAIL=admin@social-feed.local
PGADMIN_DEFAULT_PASSWORD=change_me_in_local_env
PGADMIN_PORT=5050
