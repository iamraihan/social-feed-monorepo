model RefreshToken {
    id String @id @default(uuid())

    // The owning user; cascade so token rows die with the user.
    userId String @map("user_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Family groups all rotations of a single login session. Reuse detection
    // revokes the entire family in one statement.
    familyId String @map("family_id")

    // sha256(rawRefreshToken) — raw token is never stored at rest.
    tokenHash String @unique @map("token_hash") @db.VarChar(64)

    // Reuse-detection trip-wire: when a token already marked `used` is presented
    // at /auth/refresh again, the family is revoked. Do not delete `used` rows
    // immediately — the cleanup cron retires them after 8 days.
    used    Boolean @default(false)
    revoked Boolean @default(false)

    expiresAt DateTime @map("expires_at")
    createdAt DateTime @default(now()) @map("created_at")

    // Forensics on suspicious activity.
    userAgent String? @map("user_agent")
    ipAddress String? @map("ip_address") @db.VarChar(45)

    @@index([userId])
    @@index([familyId])
    @@index([expiresAt])
    @@map("refresh_tokens")
}
